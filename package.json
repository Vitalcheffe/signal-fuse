{
  "name": "signal-fuse",
  "version": "1.0.0",
  "description": "Ask 3 models, get 1 truth. BFT-inspired multi-LLM consensus CLI.",
  "type": "module",
  "bin": {
    "signal-fuse": "./bin/signal-fuse.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "tsx --test src/__tests__/*.test.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "llm",
    "consensus",
    "ai",
    "cli",
    "multi-model",
    "bft",
    "agents",
    "openai",
    "anthropic",
    "gemini",
    "gpt",
    "claude"
  ],
  "author": "Vitalcheffe",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Vitalcheffe/signal-fuse.git"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0"
  }
}
